<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Withdraws - RblxPlus</title>
    <link rel="stylesheet" href="/public/userview.css">
    <style>
        #content {
            display: none;
        }
    </style>
</head>
<body>
    <div id="content">
        <%- include('partials/sidebar') %>
        <div class="content">
            <h1>User Details</h1>
            <%- include('../partials/notifications') %>
            <% if (user) { %>
                <div class="user-card">
                    <img src="<%- user.imageUrl %>" alt="<%- user.user %>">
                    <div class="user-info">
                        <form class="account-form" action="/admin/ASFASJFQWFQ@@Idqwriwqqidfqwfqwfoqwfqwoqwqwfjqwasdasdad/admin/users/<%- user.robloxId %>/view" method="post">
                            <input type="hidden" name="_csrf" id="_csrf" value="<%= csrfToken %>">
                            <div class="form-group">
                                <label for="name">Username</label>
                                <input type="text" id="name" value="<%- user.user %>" disabled>
                            </div>
                        
                            <div class="form-group">
                                <label for="welcome-message">Points</label>
                                <input type="number" id="welcome-message" value="<%- user.points %>" name="points">
                            </div>
                            <div class="form-buttons">
                                <button class="save-change" type="submit">Save Change</button>
                                <button class="cancel" type="button">Cancel</button>
                            </div>
                        </form>
                    </div>
                </div>
                <!-- Transactions Table -->
                <div class="transactions">
                    <h2>Transaction History</h2>
                    <table>
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Pass Name</th>
                                <th>Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (arrTrans) { %>
                                <% arrTrans.forEach(transaction => { %>
                                    <tr>
                                        <td><%= dayjs(transaction.date).format('DD/MM/YYYY') %></td>
                                        <td><%- transaction.passName %></td>
                                        <td><%- transaction.robuxAmount %></td>
                                        <td><%- transaction.status === 'pending' ? 'Pending' : 'Completed' %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4">No transactions found.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <p class="no-user">No user found.</p>
            <% } %>
        </div>
    </div>

    <script>
        const token = localStorage.getItem('authToken');

        if (!token) {
            window.location.href = '/login';
        } else {
            document.getElementById('content').style.display = 'block';
        }
    </script>
</body>
</html>