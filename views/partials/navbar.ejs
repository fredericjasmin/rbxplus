<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Responsive Navbar</title>
    <link rel="stylesheet" href="/public/navbar.css">
    <link href="https://cdn.lineicons.com/4.0/lineicons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
    <link rel="shortcut icon" href="/public/image/rrbxplus.png" type="image/x-icon">
  </head>
<body>
    <div id="navbar">
       
        <div id="navid">
            


          <div class="icon-container">
            <h3>
                <a href="/profile" id="profile1">
                    <i class="lni lni-user icon"></i> PROFILE
                </a>
            </h3>
        </div>
        <div class="icon-container">
            <h3>
                <a href="/surveys" id="surveys1">
                    <i class="lni lni-star-empty icon"></i>SURVEYS
                </a>
            </h3>
        </div>
        <div class="icon-container">
            <h3>
                <a href="/withdraw" id="withdraw1">
                    <i class="lni lni-cart icon"></i>WITHDRAW
                </a>
            </h3>
        </div>
        <div class="icon-container">
            <h3>
                <a href="/ranking" id="DASHBOARD">
                    <i class="lni lni-cup icon"></i>RANKING
                </a>
            </h3>
        </div>
     
        <div class="icon-container">
          <h3>
              <a href="/games" id="games1">
                  <i class="lni lni-game icon"></i>GAMES
              </a>
          </h3>
      </div>



        
        <div class="icon-container">
          <h3>
              <a href="/extra" id="extra1">
                  <i class="lni lni-customer icon"></i> EXTRA R$
              </a>
          </h3>
      </div>
        <div class="icon-container">
            <h3>
                <a href="/faq" id="faq1">
                    <i class="lni lni-question-circle icon"></i>FAQ
                </a>
            </h3>
        </div>
        <div class="icon-container">
            <h3>
                <a href="/goal" id="goal">
                    <i class="lni lni-sketch icon"></i>GOAL
                </a>
            </h3>
        </div>
        <div class="icon-container">
            <h3>
                <a href="https://discord.gg/7BCq5z9V2d" target="_blank" id="discord">
                    <i class="lni lni-discord-alt icon"></i>SUPPORT
                </a>
            </h3>
        </div>

        </div>
        <div class="menu-icon" id="menu-icon">
            <i class="lni lni-menu"></i>
        </div>
        <div class="menu-icon" id="close-icon">
            <i class="lni lni-close"></i>
        </div>

    

    </div>

    <div id="language-switcher">
      <a href="?lng=en"><img src="/public/image/english.png" id="en-flag" alt="English"></a>
      <a href="?lng=es"><img src="/public/image/spanish.png" id="es-flag" alt="Español"></a>
  </div>
    
    <script src="/public/navbar.js"></script>

    <script src="https://unpkg.com/i18next/dist/umd/i18next.min.js"></script>
 <script src="https://unpkg.com/i18next-browser-languagedetector/i18nextBrowserLanguageDetector.min.js"></script>
 <script src="https://unpkg.com/jquery/dist/jquery.min.js"></script>
 <script>
    i18next
      .use(i18nextBrowserLanguageDetector)
      .init({
        fallbackLng: 'en',
        debug: true,
        resources: {
          en: {
            translation: {
              "lang-es": "Spanish",
              "lang-en": "English"
            }
          },
          es: {
            translation: {
              "lang-es": "Español",
              "lang-en": "Ingles"
            }
          }
        }
      }, function(err, t) {
        // Actualizar las traducciones
        updateContent();
      });

   function updateContent() {
     document.querySelectorAll('[data-translate]').forEach(function(element) {
       const key = element.getAttribute('data-translate');
       element.textContent = i18next.t(key);
     });
   }

   // Cambiar idioma al hacer clic
   document.getElementById('change-lang-es').addEventListener('click', function() {
     i18next.changeLanguage('es', updateContent);
   });

   document.getElementById('change-lang-en').addEventListener('click', function() {
     i18next.changeLanguage('en', updateContent);
   });
 </script>
</body>
</html>