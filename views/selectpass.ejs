<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RbxPlus: Earn Free Robux In Few Minutes!</title>
    <link rel="stylesheet" href="/public/selectpass.css">
    <link rel="shortcut icon" href="/public/image/rrbxplus.png" type="image/x-icon">
    <link rel="icon" href="/public/image/rrbxplus.png" type="image/x-icon">
    
</head>

<body>
  <%- include('partials/preload') %>
    <%- include('partials/navbar') %>
        <div id="login">
            <div id="log1">
                <h1 data-translate="thirdstep">Third step</h1>
            </div>

            <%- include(`partials/notifications`)%>

                            <h1 id="selectpass" data-translate="selectpass">Select the gamepass you made</h1>
                            <form action="/game/selectpass" method="post" id="gamePassForm">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <div id="cards-container">
                                    <% if (passes) { %>
                                        <% passes.forEach(pass=> { %>
                                            <div id="card" class="card">
                                                <img src="<%- pass.imageUrl %>" alt="<%- pass.name %>">
                                                <div id="card-title"><%- pass.name %></div>
                                                <input type="hidden" name="passName" value="<%- pass.name %>">
                                                <input type="hidden" name="passId" value="<%- pass.id %>">
                                                <input type="hidden" name="passImage" value="<%- pass.imageUrl %>">
                                                <input type="hidden" name="passPrice" value="<%- pass.price %>">
                                                <p style="color: black;">Price: <%- pass.price %> Robux</p>
                                            </div>
                                            <% }) %>
                                                <% } else { %>
                                                    <p>No passes found.</p>
                                                    <% } %>
                                </div>
                                <div id="butn">
                                    <button type="submit" id="btnOk">Withdraw</button>
                                </div>
                            </form>
        </div>

        <script src="/public/selectCard.js"></script>
        
        <script src="https://unpkg.com/i18next/dist/umd/i18next.min.js"></script>
    <script src="https://unpkg.com/i18next-browser-languagedetector/i18nextBrowserLanguageDetector.min.js"></script>
    <script src="https://unpkg.com/jquery/dist/jquery.min.js"></script>
    <script>
       i18next
         .use(i18nextBrowserLanguageDetector)
         .init({
           fallbackLng: 'en',
           debug: true,
           resources: {
             en: {
               translation: {
                 "thirdstep": "Third Step",
                 "selectpass": "Select the gamepass you made",
               }
             },
             es: {
               translation: {
                 "thirdstep": "Tercer Paso",
                 "selectpass": "Seleccione el gamepass que creo",
               }
             }
           }
         }, function(err, t) {
           updateContent();
         });

      function updateContent() {
        document.querySelectorAll('[data-translate]').forEach(function(element) {
          const key = element.getAttribute('data-translate');
          element.textContent = i18next.t(key);
        });
      }

      // Cambiar idioma al hacer clic
      document.getElementById('change-lang-es').addEventListener('click', function() {
        i18next.changeLanguage('es', updateContent);
      });

      document.getElementById('change-lang-en').addEventListener('click', function() {
        i18next.changeLanguage('en', updateContent);
      });
    </script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const socket = new WebSocket('ws://rbxplus.com/');

    // Eventos de conexión, cierre y mensajes
    socket.onopen = () => {
        console.log('Connected to WebSocket server');
    };

    socket.onclose = () => {
        console.log('Disconnected from WebSocket server');
    };

    socket.onerror = (error) => {
        console.error('WebSocket error:', error);
    };
});
</script>

<script async src="https://www.googletagmanager.com/gtag/js?id=G-J55SK0YRQ8"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-J55SK0YRQ8');
</script>
</body>

</html>