<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RbxPlus: Earn Free Robux In Few Minutes!</title>
    <link rel="stylesheet" href="/public/surveys.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <link rel="shortcut icon" href="/public/image/rrbxplus.png" type="image/x-icon">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <%- include('partials/preload') %>
    <%- include('partials/navbar') %>

    <div id="container">
        <header class="banner">
            <h1 id="h1textbanner">Earn R$ <span id="auto-type" class="auto-type"></span></h1> 
        </header>
          
        <div class="marquee-container">
            <div class="marquee">
                <p data-translate="check">Tip: It's recommended to check every day to see if there are new surveys available.</p>
            </div>
        </div>

        <div id="sidebar">
            <h1 id="textsurvey" data-translate="textsurvey">SURVEYS</h1>

            <div><button class="offerss" onclick="changewall('adgem')"><img src="/public/image/adgate1.png" alt="offers"></button></div>
	        <div><button class="offerss" onclick="changewall('cpx')"><img src="/public/image/cpx1.png" alt="offers"></button></div>
            <div><button class="offerss" onclick="changewall('lootably')"><img src="/public/image/lootably1.png" alt="offers"></button></div>
            <div><button class="offerss" onclick="changewall('ayet')"><img src="/public/image/ayet1.png" alt="offers"></button></div>
            <div><button class="offerss" onclick="changewall('rbxplus')"><img src="/public/image/social1.png" alt="offers"></button></div>
        </div>

        <div id="walloffer">
            <iframe loading="lazy" width="100%" frameBorder="0" height="630px" id="adgem" src="https://wall.adgaterewards.com/nqaZqmY/<%- user.username %>"></iframe>
            <iframe loading="lazy" width="100%" frameBorder="0" height="630px" id="lootably" style="display:none;" src="https://wall.lootably.com/?placementID=clzkzwzpi01n8012835n79jtp&sid=<%- user.username %>"></iframe>
            <iframe loading="lazy" width="100%" frameBorder="0" height="630px"  id="cpx" style="display:none;" src="https://offers.cpx-research.com/index.php?app_id=23874&ext_user_id=<%- user.username %>&secure_hash={secure_hash}&username=<%- user.username %>&email={user_email}&subid_1=&subid_2"></iframe>
            <iframe loading="lazy" width="100%" frameBorder="0" height="630px" id="ayet" style="display:none;" src="https://www.ayetstudios.com/offers/web_offerwall/17316?external_identifier=<%- user.username %>"></iframe>
            <% if (hasYouTubeAction && hasTikTokAction && hasFbAction && hasIgAction) { %>
              <p class="offer-completed" id="rbxplus" style="display: none;">You have already completed all offers.</p>
          <% } else { %>
            <div class="offers-rbxplus" id="rbxplus" style="display: none;">
                <% if (!hasYouTubeAction) { %>
                <div class="offer-rbxplus">
                    <i class="fab fa-youtube offer-icon-rbxplus"></i>
                    <div class="offer-info-rbxplus">
                        <h4>Youtube</h4>
                        <p>Follow the Youtube Now</p>
                    </div>
                    <div class="points-rbxplus">
                        <form action="/youtube" method="post" id="youtube-form">
                            <input type="hidden" name="_csrf" id="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="reward-button"><span>0.5 points</span></button>
                        </form>
                        <div class="overlay" id="overlay" style="visibility: hidden;">
                            <div class="notification">
                                <div class="success-icon"><i class='bx bx-check-circle'></i></div>
                                <h2>Offer completed</h2>
                                <p>You received 0.5 R$.</p>
                                <button class="close-btn" onclick="closeNotification()">OK</button>
                            </div>
                        </div>
                    </div>
                </div>
                <% } %>
        
                <% if (!hasTikTokAction) { %>
                <div class="offer-rbxplus">
                    <i class="fab fa-tiktok offer-icon-rbxplus"></i>
                    <div class="offer-info-rbxplus">
                        <h4>Tiktok</h4>
                        <p>Follow the Tiktok Now</p>
                    </div>
                    <div class="points-rbxplus">
                        <form action="/tiktok" method="post" id="tiktok-form">
                            <input type="hidden" name="_csrf" id="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="reward-button"><span>0.5 points</span></button>
                        </form>
                        <div class="overlay" id="overlay" style="visibility: hidden;">
                            <div class="notification">
                                <div class="success-icon"><i class='bx bx-check-circle'></i></div>
                                <h2>Offer completed</h2>
                                <p>You received 0.5 R$.</p>
                                <button class="close-btn" onclick="closeNotification()">OK</button>
                            </div>
                        </div>
                    </div>
                </div>
                <% } %>
        
                <% if (!hasFbAction) { %>
                <div class="offer-rbxplus">
                    <i class="fab fa-facebook offer-icon-rbxplus"></i>
                    <div class="offer-info-rbxplus">
                        <h4>Facebook</h4>
                        <p>Follow the Facebook Now</p>
                    </div>
                    <div class="points-rbxplus">
                        <form action="/facebook" method="post" id="fb-form">
                            <input type="hidden" name="_csrf" id="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="reward-button"><span>0.5 points</span></button>
                        </form>
                        <div class="overlay" id="overlay" style="visibility: hidden;">
                            <div class="notification">
                                <div class="success-icon"><i class='bx bx-check-circle'></i></div>
                                <h2>Offer completed</h2>
                                <p>You received 0.5 R$.</p>
                                <button class="close-btn" onclick="closeNotification()">OK</button>
                            </div>
                        </div>
                    </div>
                </div>
                <% } %>
        
                <% if (!hasIgAction) { %>
                <div class="offer-rbxplus">
                    <i class="fab fa-instagram offer-icon-rbxplus"></i>
                    <div class="offer-info-rbxplus">
                        <h4>Instagram</h4>
                        <p>Follow the Instagram Now</p>
                    </div>
                    <div class="points-rbxplus">
                        <form action="/instagram" method="post" id="ig-form">
                            <input type="hidden" name="_csrf" id="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="reward-button"><span>0.5 points</span></button>
                        </form>
                        <div class="overlay" id="overlay" style="visibility: hidden;">
                            <div class="notification">
                                <div class="success-icon"><i class='bx bx-check-circle'></i></div>
                                <h2>Offer completed</h2>
                                <p>You received 0.5 R$.</p>
                                <button class="close-btn" onclick="closeNotification()">OK</button>
                            </div>
                        </div>
                    </div>
                </div>
                <% } %>
        </div>
        <% } %>
        
    </div>

    <script async src="https://cdn.cpx-research.com/assets/js/script_tag_v2.0.js"></script>
    <script>

function showNotification() {
            document.getElementById('overlay').classList.add('show');
        }


      function closeNotification() {
            document.getElementById('overlay').style.visibility = 'hidden';
        }

        window.onload = function() {
            showNotification();
        };
    </script>
    <script>
        function changewall(id) {
            $('#walloffer iframe').hide();
            $('.offer-completed').hide();
            $('.offers-rbxplus').hide();

            
            if (id === 'rbxplus') {
                $('#' + id).attr('src', $('#' + id).data('src')).show(); 
            } else {
                $('#' + id).attr('src', $('#' + id).data('src')).show(); 
            }
        }
    </script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
      document.getElementById('youtube-form').addEventListener('submit', function(event) {
          event.preventDefault();
          const csrfToken = document.getElementById('_csrf').value;
          fetch('/youtube', {
              method: 'POST',
              headers: {
                  'Content-Type': 'application/json',
                  'CSRF-Token': csrfToken,
              },
              body: JSON.stringify({}),
          })
          .then(response => response.json())
          .then(data => {
              if (data.redirectUrl) {
                  window.open(data.redirectUrl, '_blank');
                  // Muestra la notificación
                  document.getElementById('overlay').style.visibility = 'visible';
              }
          })
          .catch(error => console.error('Error:', error));
      });
  });
</script>

